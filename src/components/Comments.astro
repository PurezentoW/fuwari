---
import { commentConfig } from "@/config";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";

if (!commentConfig.enable || !commentConfig.envId) return;
---

<div
	id="tcomment"
	data-env-id={commentConfig.envId}
	data-region={commentConfig.region || ""}
	class="mt-6 pt-6 border-t border-[var(--line-divider)]"
>
	<div class="transition font-bold text-lg text-neutral-900 dark:text-neutral-100 relative ml-8 mb-2
		before:w-1 before:h-4 before:rounded-md before:bg-[var(--primary)]
		before:absolute before:left-[-16px] before:top-[5.5px]">
		{i18n(I18nKey.comments)}
	</div>
	<div id="twikoo-container"></div>
</div>

<script>
	function loadTwikoo(): Promise<void> {
		return new Promise((resolve) => {
			if ((window as any).twikoo) {
				resolve();
				return;
			}
			const script = document.createElement("script");
			script.src = "https://cdn.jsdelivr.net/npm/twikoo@1.7.9/dist/twikoo.min.js";
			script.onload = () => resolve();
			script.onerror = () => resolve();
			document.head.appendChild(script);
		});
	}

	function initTwikoo() {
		const container = document.getElementById("tcomment");
		if (!container) return;

		const envId = container.dataset.envId;
		if (!envId) return;

		const region = container.dataset.region || undefined;

		loadTwikoo().then(() => {
			if (typeof (window as any).twikoo === "undefined") return;
			(window as any).twikoo.init({
				envId,
				region,
				el: "#twikoo-container",
			});
		});
	}

	// Initial load
	initTwikoo();

	// Re-init on Swup page transitions
	document.addEventListener("astro:page-load", initTwikoo);

	// Fallback: hook into Swup directly (Swup 4 hooks API)
	const waitForSwup = setInterval(() => {
		if ((window as any).swup) {
			clearInterval(waitForSwup);
			(window as any).swup.hooks.on("content:replace", initTwikoo);
		}
	}, 200);

	// Safety: stop polling after 10s
	setTimeout(() => clearInterval(waitForSwup), 10000);
</script>
